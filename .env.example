# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kubepath_secret

# KubePath Server
KUBEPATH_HOST=0.0.0.0
KUBEPATH_PORT=8000

# Kubernetes (optional - uses default kubeconfig if not set)
# KUBECONFIG=/path/to/kubeconfig

# AWS (optional - uses default credential chain if not set)
# AWS_PROFILE=default
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
